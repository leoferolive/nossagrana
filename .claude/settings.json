{
  "permissions": {
    "allow": [
      "Bash(pnpm:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(git fetch:*)",
      "Bash(git branch:*)",
      "Bash(gh pr:*)",
      "Bash(gh run:*)",
      "mcp__plugin_playwright_playwright__browser_navigate",
      "mcp__plugin_playwright_playwright__browser_click",
      "mcp__plugin_playwright_playwright__browser_fill_form",
      "mcp__plugin_playwright_playwright__browser_snapshot",
      "mcp__plugin_playwright_playwright__browser_evaluate",
      "mcp__plugin_playwright_playwright__browser_type",
      "mcp__plugin_playwright_playwright__browser_console_messages",
      "mcp__plugin_playwright_playwright__browser_network_requests",
      "mcp__plugin_playwright_playwright__browser_run_code",
      "mcp__plugin_playwright_playwright__browser_take_screenshot",
      "mcp__plugin_playwright_playwright__browser_navigate_back",
      "mcp__plugin_playwright_playwright__browser_press_key",
      "mcp__plugin_playwright_playwright__browser_tabs",
      "mcp__plugin_playwright_playwright__browser_wait_for",
      "mcp__plugin_playwright_playwright__browser_close"
    ],
    "deny": [
      "Bash(cat .env:*)",
      "Bash(cat *secret*:*)",
      "Bash(rm -rf /:*)",
      "Bash(git push --force:*)",
      "Bash(DROP DATABASE:*)",
      "Bash(DROP TABLE:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "The user's tool call is: $ARGUMENTS. If this is a 'git commit' command, check: have ALL tests (API + Web) been run and passed in this session? If tests have NOT been run yet, respond with JSON {\"decision\": \"block\", \"reason\": \"Rode /run-tests antes de commitar. Web tests não rodam no CI.\"}. If tests passed, allow. If it is NOT a git commit, always allow."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "filepath=\"$CLAUDE_FILE_PATH\"; if echo \"$filepath\" | grep -qE '\\.(ts|tsx|js|jsx|mjs|cjs|json|md|yaml|yml|css|html|sql)$'; then cd /home/leoferolive/projetos/nossagrana && pnpm exec prettier --write \"$filepath\" 2>/dev/null; pnpm exec oxlint \"$filepath\" 2>/dev/null; fi",
            "timeout": 15000
          }
        ]
      }
    ]
  }
}
